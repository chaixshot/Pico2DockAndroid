<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="visible"
    tools:context=".MainActivity"
    tools:visibility="visible">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="fill_parent"
        app:cardBackgroundColor="#ff292929"
        app:cardCornerRadius="32dp"
        app:contentPadding="5dp"
        tools:ignore="MissingConstraints">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:id="@+id/CardBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:contentPaddingBottom="10dp"
                app:contentPaddingLeft="24dp"
                app:contentPaddingRight="24dp"
                app:contentPaddingTop="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageView2"
                            android:layout_width="27dp"
                            android:layout_height="27dp"
                            app:srcCompat="@mipmap/ic_launcher_round" />

                        <TextView
                            android:id="@+id/textView3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/app_name"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Convert the APK app from Floating to Dashboard Dock for Pico 4, alike File Manager." />

                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Allow to multitasking while in fullscreen immersive app." />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="2dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="fill_parent"
                            android:gravity="bottom"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textView7"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:enabled="false"
                                android:text="A large APK file might run out of memory, using desktop version instead."
                                android:textSize="12sp"
                                android:visibility="visible" />

                            <TextView
                                android:id="@+id/textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:enabled="false"
                                android:text="Press Pico Optimize Memory to preserve more RAM usage to do this task"
                                android:textSize="12sp"
                                android:visibility="visible" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textView6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Made by H@mer"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/button"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginLeft="10dp"
                                android:onClick="OpenGithubPage"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:text="Github Page"
                                android:tooltipText="Open Github page in browser" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/CardFiles"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="5dp"
                app:cardCornerRadius="32dp">

                <ListView
                    android:id="@+id/ListViewFiles"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                </ListView>

                <TextView
                    android:id="@+id/TextFileSelectHint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:onClick="SelectFile"
                    android:text="Click here to select file"
                    android:textSize="24sp" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ControlBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/ButtonStart"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:enabled="false"
                            android:onClick="ButtonStartPressed"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:text="Start"
                            android:tooltipText="Start convert process" />

                        <Button
                            android:id="@+id/ButtonClear"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:enabled="false"
                            android:onClick="ButtonClearPressed"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:text="Clear"
                            android:tooltipText="Clear all files" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/ButtonCancel"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:enabled="false"
                        android:onClick="ButtonCancelPressed"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="Cancle"
                        android:tooltipText="Terminate processing task" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        app:cardCornerRadius="32dp"
                        app:cardUseCompatPadding="false"
                        app:contentPaddingBottom="10dp"
                        app:contentPaddingLeft="20dp"
                        app:contentPaddingRight="20dp"
                        app:contentPaddingTop="10dp">

                        <Switch
                            android:id="@+id/SwitchHideDock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="0"
                            android:text="Hide Dock"
                            android:tooltipText="Put the app on to of everything incluing dock and keyboard" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        app:cardCornerRadius="32dp"
                        app:contentPaddingLeft="20dp"
                        app:contentPaddingRight="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <CheckBox
                                android:id="@+id/CheckboxRePackage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-5dp"
                                android:layout_marginBottom="-5dp"
                                android:text="New package name"
                                android:tooltipText="Attempting to auto-rename the package allows to install app alongside the normal version.\n\nPackage is more likey not to work, depending the app is writtcn and its protection." />

                            <CheckBox
                                android:id="@+id/CheckboxRePackageAdv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-5dp"
                                android:layout_marginBottom="-5dp"
                                android:text="Advance mode"
                                android:tooltipText="Rename the package name in advanced mode if normal is not working." />
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        app:cardCornerRadius="32dp"
                        app:contentPaddingLeft="20dp"
                        app:contentPaddingRight="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/TextRename"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-4dp"
                                android:layout_marginBottom="-4dp"
                                android:layout_weight="1"
                                android:ems="10"
                                android:hint="After app name"
                                android:inputType="text"
                                android:textSize="16sp"
                                android:tooltipText="Add text to the end of the original app name. \n\nLeave it black to do nothing. \n\nNot working for an app that can change its name through its settings." />

                            <CheckBox
                                android:id="@+id/CheckboxRename"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-3dp"
                                android:layout_marginBottom="-3dp"
                                android:text="Rename"
                                android:tooltipText="Change the entire app name instead of adding text after." />
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/CardStatus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                app:cardCornerRadius="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="6dp"
                        android:layout_marginTop="-4dp"
                        android:layout_marginRight="6dp">

                        <ProgressBar
                            android:id="@+id/StatusProgressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:progress="40"
                            android:scaleY="4" />

                        <TextView
                            android:id="@+id/PercentText"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingTop="1dp"
                            android:text="40%"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/StatusText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="24dp"
                        android:layout_marginRight="24dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>